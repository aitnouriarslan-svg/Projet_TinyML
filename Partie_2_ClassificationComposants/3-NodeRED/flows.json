[
    {
        "id": "flow1",
        "type": "tab",
        "label": "Comptage Composants",
        "disabled": false,
        "info": "Flow Node-RED pour compter les composants électroniques détectés par l'Arduino"
    },
    {
        "id": "serial_in",
        "type": "serial in",
        "z": "flow1",
        "name": "Arduino Serial",
        "serial": "serial_port",
        "x": 120,
        "y": 200,
        "wires": [["parse_data"]]
    },
    {
        "id": "serial_port",
        "type": "serial-port",
        "serialport": "COM3",
        "serialbaud": "115200",
        "databits": "8",
        "parity": "none",
        "stopbits": "1",
        "waitfor": "",
        "newline": "\\n",
        "bin": "false",
        "out": "char",
        "addchar": "",
        "responsetimeout": "10000"
    },
    {
        "id": "parse_data",
        "type": "function",
        "z": "flow1",
        "name": "Parser données",
        "func": "// Format reçu : 'classe,confiance'  ex: 'capacitor,0.87'\nvar raw = msg.payload.trim();\n\n// Ignorer les lignes de debug (commencent par '[')\nif (raw.startsWith('[') || raw.startsWith('=') || raw.startsWith('-') || raw.startsWith(' ')) {\n    return null;\n}\n\nvar parts = raw.split(',');\nif (parts.length < 2) return null;\n\nvar classe = parts[0].trim().toLowerCase();\nvar confiance = parseFloat(parts[1]);\n\n// Ignorer unknown et valeurs invalides\nif (classe === 'unknown' || isNaN(confiance)) return null;\n\nmsg.classe = classe;\nmsg.confiance = confiance;\nmsg.payload = classe;\n\nreturn msg;",
        "outputs": 1,
        "x": 310,
        "y": 200,
        "wires": [["switch_classe", "debug_out"]]
    },
    {
        "id": "debug_out",
        "type": "debug",
        "z": "flow1",
        "name": "Debug",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "x": 310,
        "y": 300,
        "wires": []
    },
    {
        "id": "switch_classe",
        "type": "switch",
        "z": "flow1",
        "name": "Switch classe",
        "property": "payload",
        "propertyType": "msg",
        "rules": [
            {"t": "eq", "v": "capacitor", "vt": "str"},
            {"t": "eq", "v": "diode", "vt": "str"},
            {"t": "eq", "v": "resistor", "vt": "str"},
            {"t": "eq", "v": "transistor", "vt": "str"}
        ],
        "checkall": "false",
        "repair": false,
        "outputs": 4,
        "x": 510,
        "y": 200,
        "wires": [
            ["counter_capacitor"],
            ["counter_diode"],
            ["counter_resistor"],
            ["counter_transistor"]
        ]
    },
    {
        "id": "counter_capacitor",
        "type": "function",
        "z": "flow1",
        "name": "Compteur Capacitor",
        "func": "var count = context.get('count') || 0;\ncount++;\ncontext.set('count', count);\nmsg.payload = count;\nreturn msg;",
        "outputs": 1,
        "x": 730,
        "y": 100,
        "wires": [["display_capacitor", "gauge_capacitor"]]
    },
    {
        "id": "counter_diode",
        "type": "function",
        "z": "flow1",
        "name": "Compteur Diode",
        "func": "var count = context.get('count') || 0;\ncount++;\ncontext.set('count', count);\nmsg.payload = count;\nreturn msg;",
        "outputs": 1,
        "x": 730,
        "y": 180,
        "wires": [["display_diode", "gauge_diode"]]
    },
    {
        "id": "counter_resistor",
        "type": "function",
        "z": "flow1",
        "name": "Compteur Resistor",
        "func": "var count = context.get('count') || 0;\ncount++;\ncontext.set('count', count);\nmsg.payload = count;\nreturn msg;",
        "outputs": 1,
        "x": 730,
        "y": 260,
        "wires": [["display_resistor", "gauge_resistor"]]
    },
    {
        "id": "counter_transistor",
        "type": "function",
        "z": "flow1",
        "name": "Compteur Transistor",
        "func": "var count = context.get('count') || 0;\ncount++;\ncontext.set('count', count);\nmsg.payload = count;\nreturn msg;",
        "outputs": 1,
        "x": 730,
        "y": 340,
        "wires": [["display_transistor", "gauge_transistor"]]
    },
