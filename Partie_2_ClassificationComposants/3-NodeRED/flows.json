    {
        "id": "reset_function",
        "type": "function",
        "z": "flow1",
        "name": "Reset tous compteurs",
        "func": "// Remet tous les compteurs à 0\nvar nodes = ['counter_capacitor', 'counter_diode', 'counter_resistor', 'counter_transistor'];\n\n// Reset via contexte global\nglobal.set('cap_count', 0);\nglobal.set('dio_count', 0);\nglobal.set('res_count', 0);\nglobal.set('tra_count', 0);\n\nmsg.payload = 0;\nreturn [msg, msg, msg, msg];",
        "outputs": 4,
        "x": 350,
        "y": 400,
        "wires": [
            ["display_capacitor", "gauge_capacitor"],
            ["display_diode", "gauge_diode"],
            ["display_resistor", "gauge_resistor"],
            ["display_transistor", "gauge_transistor"]
